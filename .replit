modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 21426
externalPort = 3000

[userenv]

[userenv.shared]
SQUARE_ENV = "sandbox"
VITE_SQUARE_ENV = "sandbox"
VITE_SQUARE_APP_ID = "sandbox-sq0idb-oShpWqWp2Mxty760KjVoeg"
VITE_SQUARE_LOCATION_ID = "LQ4ZAHJFDQ97Q"
SQUARE_LOCATION_ID = "LQ4ZAHJFDQ97Q"

[nix]
channel = "stable-25_05"
